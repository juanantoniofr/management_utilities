# Normalizar finales de línea para evitar problemas entre SO
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# HTML/CSS/JS
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Documentación
*.md text eol=lf

# Archivos binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
