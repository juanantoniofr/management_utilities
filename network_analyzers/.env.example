# DHCP Monitor Configuration
# Copy this file to .env and adjust values as needed

# Authentication credentials
# Username for the web interface (default: admin)
DHCP_ADMIN_USER=admin

# Password for the web interface
# IMPORTANT: Change this to a secure password in production
DHCP_ADMIN_PASS=changeme

# Flask environment
FLASK_ENV=production
FLASK_DEBUG=False

# Server configuration
# Listen on all interfaces
FLASK_HOST=0.0.0.0

# Port: 443 for HTTPS, 5000 for HTTP (if no SSL certs)
FLASK_PORT=443

# SSL Certificate paths (optional, uses snakeoil certs by default)
SSL_CERT_PATH=/etc/ssl/certs/ssl-cert-snakeoil.pem
SSL_KEY_PATH=/etc/ssl/private/ssl-cert-snakeoil.key

# Logging
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
